# ─── Backend PostgreSQL connection ───────────────────────────────────────────
# Copy this to .env and fill in real values — never commit .env
DB_HOST=localhost
DB_PORT=5432
DB_NAME=unico
DB_USER=postgres
DB_PASSWORD=CHANGE_ME

# ─── CORS — Frontend origin ───────────────────────────────────────────────────
FRONTEND_ORIGIN=http://localhost:5173
FRONTEND_ORIGIN_ALT=http://127.0.0.1:5173

# ─── App settings ─────────────────────────────────────────────────────────────
APP_ENV=development
DEBUG=true
